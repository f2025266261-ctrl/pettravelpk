<%- include('partials/header') %>

<section class="hero hero--media" id="home">
  <div class="hero__media" aria-hidden="true">
    <video class="hero__video" autoplay muted loop playsinline poster="/images/hero-poster.jpg" preload="metadata">
      <source src="/images/hero-bg.mp4" type="video/mp4" />
    </video>
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content">
    <span class="hero__eyebrow">
      <span aria-hidden="true">🐾</span>
      <span>Pakistan's Most Trusted Pet Relocation</span>
    </span>

    <h1 class="hero__title">
      Your Pet Deserves a <span class="accent">Five-Star</span> Journey
    </h1>

    <p class="hero__subtitle">
      Safe, certified, door-to-door pet relocation across Pakistan and worldwide — handled with love.
    </p>

    <div class="hero__actions hero__actions--primary">
      <a class="hero__button hero__button--primary" href="#contact">Get a Free Quote →</a>
      <a class="hero__button hero__button--secondary" href="#how-it-works">See How It Works ↓</a>
    </div>

    <div class="hero__trust" aria-label="Trusted by pet parents worldwide">
      <span class="hero__trust-badge">🌍 50+ Countries</span>
      <span class="hero__trust-badge">✈️ IPATA Certified</span>
      <span class="hero__trust-badge">⭐ 500+ Happy Pets</span>
      <span class="hero__trust-badge">🕐 24/7 Support</span>
    </div>
  </div>
</section>

<section class="process" id="how-it-works">
  <div class="process__inner">
    <div class="process__header reveal">
      <span class="process__eyebrow">THE PROCESS</span>
      <h2 class="process__title">Getting Your Pet There is Simple</h2>
      <p class="process__subtitle">We handle every step — you just focus on the reunion.</p>
    </div>

    <div class="process__steps" data-process-steps>
      <article class="process__step reveal" style="--step-delay: 0s;">
        <span class="process__step-number">1</span>
        <span class="process__step-icon" aria-hidden="true">📋</span>
        <h3 class="process__step-title">Tell Us About Your Pet</h3>
        <p class="process__step-text">Fill out our quick form with your pet's details, breed, destination, and travel dates.</p>
      </article>

      <article class="process__step reveal" style="--step-delay: 0.12s;">
        <span class="process__step-number">2</span>
        <span class="process__step-icon" aria-hidden="true">🩺</span>
        <h3 class="process__step-title">We Prepare Everything</h3>
        <p class="process__step-text">Our team handles health certificates, airline booking, IATA crates, and all documentation.</p>
      </article>

      <article class="process__step reveal" style="--step-delay: 0.24s;">
        <span class="process__step-number">3</span>
        <span class="process__step-icon" aria-hidden="true">✈️</span>
        <h3 class="process__step-title">Safe Departure</h3>
        <p class="process__step-text">Your pet travels in climate-controlled, IATA-approved carriers with constant monitoring.</p>
      </article>

      <article class="process__step reveal" style="--step-delay: 0.36s;">
        <span class="process__step-number">4</span>
        <span class="process__step-icon" aria-hidden="true">🏠</span>
        <h3 class="process__step-title">Happy Arrival</h3>
        <p class="process__step-text">We coordinate pickup and delivery so your pet lands safe, stress-free, and right on time.</p>
      </article>
    </div>
  </div>
</section>

<section class="services" id="services">
  <div class="services__inner">
    <div class="services__header reveal">
      <span class="services__eyebrow">WHAT WE OFFER</span>
      <h2 class="services__title">Complete Pet Relocation Services</h2>
    </div>

    <div class="services__grid">
      <article class="service-card reveal">
        <div class="service-card__icon" aria-hidden="true">✈️</div>
        <h3 class="service-card__title">International Pet Export</h3>
        <p class="service-card__text">IATA-certified export handling to 50+ countries. We manage health certs, airline booking, customs clearance.</p>
        <a class="service-card__link" href="#contact">Learn More →</a>
      </article>

      <article class="service-card reveal">
        <div class="service-card__icon" aria-hidden="true">🛬</div>
        <h3 class="service-card__title">Pet Import to Pakistan</h3>
        <p class="service-card__text">Smooth, documentation-complete import service. We handle quarantine coordination and customs.</p>
        <a class="service-card__link" href="#contact">Learn More →</a>
      </article>

      <article class="service-card reveal">
        <div class="service-card__icon" aria-hidden="true">🏨</div>
        <h3 class="service-card__title">Pet Boarding & Vet Care</h3>
        <p class="service-card__text">Safe, hygienic boarding with daily vet check-ins. Your pet gets love and attention, not just a cage.</p>
        <a class="service-card__link" href="#contact">Learn More →</a>
      </article>

      <article class="service-card reveal">
        <div class="service-card__icon" aria-hidden="true">🩸</div>
        <h3 class="service-card__title">Pet Blood Testing</h3>
        <p class="service-card__text">Certified lab testing required for international travel — fast turnaround, accurate results.</p>
        <a class="service-card__link" href="#contact">Learn More →</a>
      </article>

      <article class="service-card reveal">
        <div class="service-card__icon" aria-hidden="true">📦</div>
        <h3 class="service-card__title">IATA-Approved Crates</h3>
        <p class="service-card__text">Custom-sized, airline-compliant travel crates for all breeds and sizes.</p>
        <a class="service-card__link" href="#contact">Learn More →</a>
      </article>

      <article class="service-card reveal">
        <div class="service-card__icon" aria-hidden="true">📄</div>
        <h3 class="service-card__title">Documentation & Clearance</h3>
        <p class="service-card__text">Full paperwork: health certificates, NOCs, microchipping, and government attestations — we handle it all.</p>
        <a class="service-card__link" href="#contact">Learn More →</a>
      </article>
    </div>
  </div>
</section>

