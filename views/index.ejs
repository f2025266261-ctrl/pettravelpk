<section class="why" id="about">
  <div class="why__inner">
    <div class="why__content">
      <span class="why__eyebrow">WHY CHOOSE US</span>
      <h2 class="why__title">We Don't Just Move Pets. We Move Families.</h2>
      <p class="why__text">PetTravelPK was born from a simple belief — pets are family. Every relocation we handle is treated with the same care we'd give our own animals.</p>
      <a class="why__button" href="#contact">Book a Free Consultation →</a>
    </div>

    <div class="why__grid">
      <article class="why-card">
        <span class="why-card__icon" aria-hidden="true">🛡️</span>
        <div class="why-card__body">
          <h3 class="why-card__title">IPATA & ATA Certified</h3>
          <p class="why-card__text">Internationally accredited for safe animal transport</p>
        </div>
      </article>

      <article class="why-card">
        <span class="why-card__icon" aria-hidden="true">🌐</span>
        <div class="why-card__body">
          <h3 class="why-card__title">Door-to-Door Worldwide</h3>
          <p class="why-card__text">From your home to the destination, fully handled</p>
        </div>
      </article>

      <article class="why-card">
        <span class="why-card__icon" aria-hidden="true">🐕</span>
        <div class="why-card__body">
          <h3 class="why-card__title">All Breeds & Species</h3>
          <p class="why-card__text">Dogs, cats, birds, reptiles, exotic pets — we've done it all</p>
        </div>
      </article>

      <article class="why-card">
        <span class="why-card__icon" aria-hidden="true">📞</span>
        <div class="why-card__body">
          <h3 class="why-card__title">WhatsApp-First Support</h3>
          <p class="why-card__text">Get updates instantly on WhatsApp — no waiting on hold</p>
        </div>
      </article>
    </div>
  </div>
</section>

